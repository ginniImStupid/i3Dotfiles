# ~/.config/i3status/config

general {
    colors = true
    interval = 5
    color_good = "#859900"
    color_degraded = "#cb4b16"
    color_bad = "#dc322f"
}

order += "cpu_usage"
order += "memory"
order += "battery all"
order += "tztime local"

cpu_usage {
    format = " CPU %usage "
}

memory {
    # Crucial for 8GB users: This shows how much is actually LEFT for your games
    format = " RAM %available "
    threshold_degraded = "1G"
    format_degraded = " MEMORY LOW: %free "
}

battery all {
    format = " %status %percentage "
}

tztime local {
    format = " %d-%m-%Y %H:%M "
}
